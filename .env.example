# Workflow Automation — 시크릿 템플릿
#
# 사용법:
#   1. 이 파일을 .env로 복사: cp .env.example .env
#   2. 본인이 받은 값으로 채움
#   3. `python scripts/sync_modal_secrets.py` 실행 → .env의 값으로 Modal Secret 등록/갱신
#
# ⚠️ .env 본체는 절대 git에 커밋하지 말 것 (.gitignore에 이미 등록됨).
# 팀원 간 공유는 1Password / Slack DM / 안전 채널 사용.

# ---- HuggingFace ----
# Gemma 4 GGUF 다운로드 + BGE-M3 캐시. read 토큰이면 충분.
# 발급: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# ---- Modal (팀 공용 — 필수) ----
# 팀 전체가 단일 워크스페이스(dhwang0803)에 배포해야 sub-agent 간 RPC lookup이 통한다.
# 조장(황대원)이 발급한 공용 토큰을 안전 채널로 전달받아 그대로 채워넣을 것.
# 채운 뒤 `python scripts/setup_modal_token.py` 한 번 실행 → ~/.modal.toml에 영속화됨.
MODAL_TOKEN_ID=ak-xxxxxxxxxxxx
MODAL_TOKEN_SECRET=as-xxxxxxxxxxxx

# ---- Sub-agent Modal Secrets (IAM 인증 패턴) ----
# 자세한 절차는 docs/guides/sub_agent_modal_deploy.md 참고.
#
# 각 sub-agent Modal app은 두 개의 Modal Secret을 마운트한다:
#   (a) agent-<name>-secret    — 본인이 .env에 채워서 sync_modal_secrets.py로 등록
#   (b) cloudsql-iam-sa        — 조장이 1회 등록한 GCP SA JSON (공용, .env에 안 넣음)
#
# 아래 5키는 agent-<name>-secret 공통 스키마.
#   LLM_BASE_URL / EMBEDDING_BASE_URL:
#     llm-base 배포 후 모달 대시보드 또는 `modal deploy` stdout에서 확인.
#     패턴은 https://<WORKSPACE>--llm-base.modal.run
#   CLOUD_SQL_INSTANCE: <PROJECT_ID>:<REGION>:<INSTANCE_NAME>
#   DB_IAM_USER: cloudsql-iam-modal@<PROJECT_ID>.iam.gserviceaccount.com (공용 SA)
#   DB_NAME: workflow_automation
#
# 채운 뒤 본인 sub-agent Secret만 sync:
#   python scripts/sync_modal_secrets.py agent-skills-builder-secret
LLM_BASE_URL=https://your-llm-base-endpoint.modal.run
EMBEDDING_BASE_URL=https://your-llm-base-endpoint.modal.run
CLOUD_SQL_INSTANCE=<PROJECT_ID>:asia-northeast3:workflow-dev
DB_IAM_USER=<YOUR_EMAIL>@gmail.com
DB_NAME=workflow_automation

# Personalization sub-agent (햄햄) 전용 — agent-personalization-secret에 같이 묶임.
# 사용자별 MEMORY.md + frontmatter .md 파일이 저장되는 GCS 버킷 (REQ-004 §6).
# 조장이 1회 생성한 dev 버킷 이름으로 채운다. SA storage 권한은 가이드 §1.4.
GCS_PERSONAL_BUCKET=<GCS_BUCKET_DEV>

# ---- LangSmith (선택, 향후) ----
# Sub-agent LangGraph 추적 활성화 시 등록. 빈 값이면 tracing.py는 no-op.
# 발급: https://smith.langchain.com/
# LANGSMITH_API_KEY=ls__xxxxxxxxxxxx
