# Workflow Automation — 시크릿 템플릿
#
# 사용법:
#   1. 이 파일을 .env로 복사: cp .env.example .env
#   2. 본인이 받은 값으로 채움
#   3. `python scripts/sync_modal_secrets.py` 실행 → .env의 값으로 Modal Secret 등록/갱신
#
# ⚠️ .env 본체는 절대 git에 커밋하지 말 것 (.gitignore에 이미 등록됨).
# 팀원 간 공유는 1Password / Slack DM / 안전 채널 사용.

# ---- HuggingFace ----
# Gemma 4 GGUF 다운로드 + BGE-M3 캐시. read 토큰이면 충분.
# 발급: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# ---- Modal (팀 공용 — 필수) ----
# 팀 전체가 단일 워크스페이스(dhwang0803)에 배포해야 sub-agent 간 RPC lookup이 통한다.
# 조장(황대원)이 발급한 공용 토큰을 안전 채널로 전달받아 그대로 채워넣을 것.
# 채운 뒤 `python scripts/setup_modal_token.py` 한 번 실행 → ~/.modal.toml에 영속화됨.
MODAL_TOKEN_ID=ak-xxxxxxxxxxxx
MODAL_TOKEN_SECRET=as-xxxxxxxxxxxx

# ---- LangSmith (선택, 향후) ----
# Sub-agent LangGraph 추적 활성화 시 등록. 빈 값이면 tracing.py는 no-op.
# 발급: https://smith.langchain.com/
# LANGSMITH_API_KEY=ls__xxxxxxxxxxxx

# ---- GCS (선택, 향후 Personalization 배포 시) ----
# Personalization agent의 GCS MEMORY.md 버킷 접근.
# GCP_PROJECT_ID=workflow-automation-staging
# GCS_PERSONAL_BUCKET=workflow-automation-personal
