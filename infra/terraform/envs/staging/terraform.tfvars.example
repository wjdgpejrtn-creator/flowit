project_id  = "<GCP_PROJECT_ID>"
region      = "asia-northeast3"
environment = "staging"

# Cloud Run 배포 토글 — 이미지 빌드 + secret 등록 완료 후 true.
# 실제 staging 값은 git 추적되는 terraform.tfvars 참조 (본 example은 형식 안내용).
enable_cloud_run               = false
enable_execution_engine_worker = false

api_server_image              = ""  # AR 이미지 경로:TAG
execution_engine_worker_image = ""

api_server_service_account              = ""  # 런타임 SA 이메일
execution_engine_worker_service_account = ""

# REQ-010 frontend (단일 출처 토폴로지 A) — enable_cloud_run=true 전제.
# 런타임 SA는 terraform이 생성 (google_service_account.frontend — 최소권한).
# stage 1: enable_frontend=true + frontend_image apply → frontend_url 확인
# stage 2: 확인된 URL을 frontend_url에 채워 재apply (api_server FRONTEND_URL 반영)
enable_frontend = false
frontend_image  = ""  # AR 이미지 경로:TAG
frontend_url    = ""  # stage 2에서 배포된 frontend Cloud Run URL
