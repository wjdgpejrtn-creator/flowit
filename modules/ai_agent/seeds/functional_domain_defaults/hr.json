{
  "domain_code": "hr",
  "domain_name": "인사",
  "description": "인사 자동화 — 온보딩·휴가·평가·기념일·퇴사",
  "version": "1.0.0",
  "skill_nodes": [
    {
      "node_type": "hr_onboarding_workflow",
      "name": "신규 입사자 온보딩",
      "category": "action",
      "description": "신규 입사자 계정/권한 생성 + Slack 워크스페이스 초대 + 온보딩 자료 전송 + 멘토 매칭",
      "inputs": {
        "type": "object",
        "properties": {
          "employee_id": {"type": "string", "description": "신규 입사자의 사번/직원 ID. 인사 시스템에서 발급되며, 미발급이면 직접 정한 임시 식별자를 씁니다. 예: EMP-2026-031"},
          "employee_email": {"type": "string", "format": "email", "description": "신규 입사자의 회사 이메일. 계정 생성·자료 발송 대상. 예: 'newbie@corp.com'"},
          "department": {"type": "string", "description": "소속 부서명. 예: '플랫폼개발팀'"},
          "manager_email": {"type": "string", "format": "email", "description": "직속 매니저(상사) 이메일. 멘토 매칭·알림 대상. 예: 'manager@corp.com'"},
          "start_date": {"type": "string", "format": "date", "description": "입사(근무 시작) 날짜(YYYY-MM-DD). 예: '2026-06-15'"},
          "onboarding_doc_template_id": {"type": "string", "description": "(선택) 발송할 온보딩 자료 템플릿의 ID. 인사팀이 미리 만들어 둔 문서 템플릿 식별자입니다. 미지정 시 기본 템플릿 사용. 예: TMPL-onboard-dev"}
        },
        "required": ["employee_id", "employee_email", "department", "manager_email", "start_date"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "account_created": {"type": "boolean"},
          "slack_invite_sent": {"type": "boolean"},
          "onboarding_doc_url": {"type": "string"},
          "mentor_assigned": {"type": ["string", "null"]}
        }
      },
      "risk_level": "High",
      "required_connections": ["slack", "google"],
      "service_type": "google_workspace"
    },
    {
      "node_type": "hr_pto_request",
      "name": "휴가 신청 승인 워크플로우",
      "category": "condition",
      "description": "휴가 신청 → 잔여 일수 확인 → 매니저 승인 분기 → 캘린더 등록 + 팀 알림",
      "inputs": {
        "type": "object",
        "properties": {
          "employee_id": {"type": "string", "description": "휴가를 신청하는 직원의 사번/직원 ID. 예: EMP-1042"},
          "leave_type": {"type": "string", "enum": ["annual", "sick", "personal", "parental"], "description": "휴가 종류. annual(연차)·sick(병가)·personal(개인)·parental(육아)"},
          "start_date": {"type": "string", "format": "date", "description": "휴가 시작일(YYYY-MM-DD). 예: '2026-06-20'"},
          "end_date": {"type": "string", "format": "date", "description": "휴가 종료일(YYYY-MM-DD). 예: '2026-06-22'"},
          "reason": {"type": "string", "description": "(선택) 휴가 사유"},
          "manager_email": {"type": "string", "format": "email", "description": "승인할 매니저(상사) 이메일. 예: 'manager@corp.com'"}
        },
        "required": ["employee_id", "leave_type", "start_date", "end_date", "manager_email"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "request_id": {"type": "string"},
          "approval_status": {"type": "string", "enum": ["auto_approved", "pending", "approved", "rejected"]},
          "remaining_days": {"type": "number"},
          "calendar_event_id": {"type": ["string", "null"]}
        }
      },
      "risk_level": "Medium",
      "required_connections": ["google"],
      "service_type": "google_workspace"
    },
    {
      "node_type": "hr_review_reminder",
      "name": "평가 시즌 알림",
      "category": "action",
      "description": "분기/반기/연간 평가 시즌에 대상자에게 자가평가/동료평가 자동 알림",
      "inputs": {
        "type": "object",
        "properties": {
          "review_cycle": {"type": "string", "enum": ["quarterly", "semi_annual", "annual"], "description": "평가 주기. quarterly(분기)·semi_annual(반기)·annual(연간)"},
          "review_form_url": {"type": "string", "format": "uri", "description": "대상자가 작성할 평가 양식 페이지 URL. 예: 'https://forms.example.com/review-2026q2'"},
          "deadline": {"type": "string", "format": "date", "description": "평가 제출 마감일(YYYY-MM-DD). 예: '2026-06-30'"},
          "target_employees": {"type": "array", "items": {"type": "string"}, "description": "(선택) 알림을 보낼 대상 직원 ID 목록. 미지정 시 해당 주기 전체 대상자. 예: [\"EMP-1042\", \"EMP-2001\"]"}
        },
        "required": ["review_cycle", "review_form_url", "deadline"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "reminders_sent": {"type": "integer"},
          "campaign_id": {"type": "string"}
        }
      },
      "risk_level": "Medium",
      "required_connections": ["google", "slack"],
      "service_type": "slack"
    },
    {
      "node_type": "hr_anniversary_celebrate",
      "name": "입사 기념일 축하",
      "category": "action",
      "description": "근속 N년 직원에게 자동 축하 메시지 발송 + 팀 채널 공유",
      "inputs": {
        "type": "object",
        "properties": {
          "employee_id": {"type": "string", "description": "축하 대상 직원의 사번/직원 ID. 예: EMP-1042"},
          "anniversary_years": {"type": "integer", "minimum": 1, "description": "축하할 근속 연수(년). 예: 3"},
          "team_channel": {"type": "string", "description": "축하 메시지를 공유할 팀 Slack 채널명/채널 ID. 예: '#team-platform'"},
          "personal_message_template": {"type": "string", "description": "(선택) 개인 DM에 쓸 축하 메시지 템플릿. {name}, {years} 같은 치환 변수 사용 가능"}
        },
        "required": ["employee_id", "anniversary_years", "team_channel"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "team_message_ts": {"type": "string"},
          "dm_sent": {"type": "boolean"},
          "celebrated_at": {"type": "string", "format": "date-time"}
        }
      },
      "risk_level": "Low",
      "required_connections": ["slack"],
      "service_type": "slack"
    },
    {
      "node_type": "hr_offboarding_workflow",
      "name": "퇴사 처리 워크플로우",
      "category": "action",
      "description": "퇴사 예정자 권한 회수 일정 등록 + 자산 회수 알림 + Exit interview 예약",
      "inputs": {
        "type": "object",
        "properties": {
          "employee_id": {"type": "string", "description": "퇴사 예정자의 사번/직원 ID. 예: EMP-1042"},
          "last_working_day": {"type": "string", "format": "date", "description": "마지막 근무일(YYYY-MM-DD). 이 날 이후 권한이 회수됩니다. 예: '2026-06-30'"},
          "manager_email": {"type": "string", "format": "email", "description": "직속 매니저(상사) 이메일. 자산 회수·인수인계 알림 대상. 예: 'manager@corp.com'"},
          "hr_lead_email": {"type": "string", "format": "email", "description": "퇴사 처리를 담당할 인사 책임자 이메일. Exit interview 예약 대상. 예: 'hr@corp.com'"},
          "asset_list": {"type": "array", "items": {"type": "string"}, "description": "(선택) 회수할 회사 자산 목록. 예: [\"노트북\", \"사원증\", \"법인카드\"]"}
        },
        "required": ["employee_id", "last_working_day", "manager_email", "hr_lead_email"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "permission_revoke_scheduled_at": {"type": "string", "format": "date-time"},
          "exit_interview_event_id": {"type": "string"},
          "asset_recovery_tickets": {"type": "array", "items": {"type": "string"}}
        }
      },
      "risk_level": "High",
      "required_connections": ["google"],
      "service_type": "google_workspace"
    }
  ]
}
