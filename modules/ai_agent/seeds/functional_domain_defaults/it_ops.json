{
  "domain_code": "it_ops",
  "domain_name": "IT 운영",
  "description": "IT 운영 자동화 — 배포 승인·권한 요청·장애·비밀번호·미팅룸",
  "version": "1.0.0",
  "skill_nodes": [
    {
      "node_type": "it_ops_deploy_approval",
      "name": "배포 승인 워크플로우",
      "category": "condition",
      "description": "프로덕션 배포 요청 시 환경/시간/영향도 기준 자동/수동 승인 분기",
      "inputs": {
        "type": "object",
        "properties": {
          "service_name": {"type": "string"},
          "environment": {"type": "string", "enum": ["staging", "production"]},
          "commit_sha": {"type": "string"},
          "deployer_id": {"type": "string"},
          "auto_approve_in_business_hours": {"type": "boolean", "default": true},
          "approval_channel": {"type": "string"}
        },
        "required": ["service_name", "environment", "commit_sha", "deployer_id"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "approval_status": {"type": "string", "enum": ["auto_approved", "pending_manual", "rejected"]},
          "approver_id": {"type": ["string", "null"]},
          "decided_at": {"type": "string", "format": "date-time"}
        }
      },
      "risk_level": "High",
      "required_connections": ["slack"],
      "service_type": "slack"
    },
    {
      "node_type": "it_ops_access_request",
      "name": "권한 부여 요청 처리",
      "category": "condition",
      "description": "권한 요청 → 책임자 승인 → 자동 권한 부여 + 만료 일자 등록",
      "inputs": {
        "type": "object",
        "properties": {
          "requester_id": {"type": "string"},
          "resource": {"type": "string"},
          "permission_level": {"type": "string", "enum": ["read", "write", "admin"]},
          "reason": {"type": "string"},
          "expires_in_days": {"type": "integer", "default": 30, "minimum": 1, "maximum": 365},
          "approver_id": {"type": "string"}
        },
        "required": ["requester_id", "resource", "permission_level", "reason", "approver_id"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "request_id": {"type": "string"},
          "approval_status": {"type": "string", "enum": ["approved", "denied", "pending"]},
          "expires_at": {"type": ["string", "null"], "format": "date-time"}
        }
      },
      "risk_level": "High",
      "required_connections": ["slack"],
      "service_type": "slack"
    },
    {
      "node_type": "it_ops_incident_pager",
      "name": "장애 알림 통합 페이저",
      "category": "action",
      "description": "장애 감지 시 PagerDuty/Slack/Linear 동시 알림 + 인시던트 채널 자동 생성",
      "inputs": {
        "type": "object",
        "properties": {
          "service_name": {"type": "string"},
          "severity": {"type": "string", "enum": ["sev1", "sev2", "sev3"]},
          "summary": {"type": "string"},
          "detected_at": {"type": "string", "format": "date-time"},
          "oncall_user_id": {"type": "string"},
          "linear_team_id": {"type": "string"}
        },
        "required": ["service_name", "severity", "summary", "oncall_user_id"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "incident_channel": {"type": "string"},
          "linear_issue_url": {"type": "string"},
          "pager_dispatched": {"type": "boolean"}
        }
      },
      "risk_level": "High",
      "required_connections": ["slack", "linear"],
      "service_type": "slack"
    },
    {
      "node_type": "it_ops_password_reset",
      "name": "비밀번호 초기화 자동화",
      "category": "action",
      "description": "본인 인증 후 임시 비밀번호 생성 + 사내 메일/SMS 발송",
      "inputs": {
        "type": "object",
        "properties": {
          "employee_id": {"type": "string"},
          "verification_token": {"type": "string"},
          "delivery_channel": {"type": "string", "enum": ["email", "sms"]},
          "destination": {"type": "string"}
        },
        "required": ["employee_id", "verification_token", "delivery_channel", "destination"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "reset_request_id": {"type": "string"},
          "temp_password_sent": {"type": "boolean"},
          "expires_at": {"type": "string", "format": "date-time"}
        }
      },
      "risk_level": "Restricted",
      "required_connections": ["google"],
      "service_type": "google_workspace"
    },
    {
      "node_type": "it_ops_meeting_room_provision",
      "name": "미팅룸 예약 자동화",
      "category": "action",
      "description": "회의 요청자가 시간/규모 입력 → 가능한 미팅룸 자동 예약 + 캘린더 등록 + 참석자 알림",
      "inputs": {
        "type": "object",
        "properties": {
          "organizer_email": {"type": "string", "format": "email"},
          "start_datetime": {"type": "string", "format": "date-time"},
          "end_datetime": {"type": "string", "format": "date-time"},
          "attendees": {"type": "array", "items": {"type": "string", "format": "email"}, "minItems": 1},
          "capacity_required": {"type": "integer", "minimum": 1},
          "requires_video": {"type": "boolean", "default": false}
        },
        "required": ["organizer_email", "start_datetime", "end_datetime", "attendees", "capacity_required"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "room_name": {"type": "string"},
          "calendar_event_id": {"type": "string"},
          "invites_sent": {"type": "integer"}
        }
      },
      "risk_level": "Medium",
      "required_connections": ["google"],
      "service_type": "google_workspace"
    }
  ]
}
