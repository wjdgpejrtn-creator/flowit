        <mxCell id="h2" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=16;fontStyle=1;" value="② 권한 미들웨어 (Permission Middleware - Chain of Responsibility)" vertex="1">
          <mxGeometry height="30" width="800" x="80" y="660" as="geometry" />
        </mxCell>
        <mxCell id="permMW" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«Facade»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;PermissionMiddleware&lt;/b&gt;&lt;hr/&gt;◇ checkers: list[BaseChecker]&lt;hr/&gt;◎ check_permission(req) → PermissionCheckResponse&lt;br/&gt;◎ check_node_permission(user_id, node_id) → dict&lt;br/&gt;◎ register_checker(checker) → None" vertex="1">
          <mxGeometry height="200" width="320" x="80" y="700" as="geometry" />
        </mxCell>
        <mxCell id="baseChk" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«abstract» «Handler»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;BaseChecker&lt;/b&gt;&lt;hr/&gt;◇ next_checker: Optional[BaseChecker]&lt;hr/&gt;&lt;i&gt;◎ check(req) → PermissionCheckResponse&lt;/i&gt;&lt;br/&gt;◎ set_next(checker) → BaseChecker" vertex="1">
          <mxGeometry height="180" width="280" x="440" y="700" as="geometry" />
        </mxCell>
        <mxCell id="permReq" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«dataclass»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;PermissionCheckRequest&lt;/b&gt;&lt;hr/&gt;◇ user_id: UUID&lt;br/&gt;◇ resource_type: Literal[&#39;node&#39;, &#39;workflow&#39;, &#39;skill&#39;, &#39;credential&#39;, &#39;agent_memory&#39;]&lt;br/&gt;◇ resource_id: str&lt;br/&gt;◇ action: Literal[&#39;read&#39;, &#39;write&#39;, &#39;execute&#39;, &#39;delete&#39;]" vertex="1">
          <mxGeometry height="200" width="320" x="760" y="650" as="geometry" />
        </mxCell>
        <mxCell id="permResp" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«dataclass»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;PermissionCheckResponse&lt;/b&gt;&lt;hr/&gt;◇ allowed: bool&lt;br/&gt;◇ reason: Optional[str]&lt;br/&gt;◇ violation_code: Optional[str]&lt;br/&gt;&lt;span style=&#39;font-size:10px;color:#666&#39;&gt;# UNAUTHORIZED_ROLE&lt;br/&gt;# OWNERSHIP_VIOLATION&lt;br/&gt;# SCOPE_VIOLATION&lt;br/&gt;# DEPARTMENT_MISMATCH&lt;br/&gt;# RISK_LEVEL_BLOCKED&lt;br/&gt;# MEMORY_SCOPE_VIOLATION&lt;/span&gt;" vertex="1">
          <mxGeometry height="240" width="310" x="1390" y="720" as="geometry" />
        </mxCell>
        <mxCell id="agentMemRepo" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«ABC» «Repository»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;AgentMemoryRepository&lt;/b&gt;&lt;hr/&gt;&lt;i&gt;◎ get_scope(memory_id) → str&lt;/i&gt;&lt;br/&gt;&lt;i&gt;◎ get_owner(memory_id) → UUID&lt;/i&gt;&lt;br/&gt;&lt;i&gt;◎ get_department(memory_id) → str&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px;color:#666&#39;&gt;# 권한 검증용 조회 전용&lt;br/&gt;# CRUD는 REQ-004 영역&lt;/span&gt;" vertex="1">
          <mxGeometry height="200" width="320" x="1560" y="460" as="geometry" />
        </mxCell>
        <mxCell id="roleChk" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b style=&#39;font-size:13px&#39;&gt;RoleChecker&lt;/b&gt;&lt;hr/&gt;◎ check(req) → Response&lt;br/&gt;&lt;br/&gt;User/Admin RBAC 검증" vertex="1">
          <mxGeometry height="120" width="240" x="80" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="ownChk" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b style=&#39;font-size:13px&#39;&gt;OwnershipChecker&lt;/b&gt;&lt;hr/&gt;◎ check(req) → Response&lt;br/&gt;&lt;br/&gt;owner_id == user_id" vertex="1">
          <mxGeometry height="120" width="240" x="360" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="scopeChk" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b style=&#39;font-size:13px&#39;&gt;ScopeChecker&lt;/b&gt;&lt;hr/&gt;◎ check(req) → Response&lt;br/&gt;&lt;br/&gt;Private/Team/Public" vertex="1">
          <mxGeometry height="120" width="240" x="640" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="deptChk" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b style=&#39;font-size:13px&#39;&gt;DepartmentChecker&lt;/b&gt;&lt;hr/&gt;◎ check(req) → Response&lt;br/&gt;&lt;br/&gt;JWT.department 매칭" vertex="1">
          <mxGeometry height="120" width="240" x="920" y="1070" as="geometry" />
