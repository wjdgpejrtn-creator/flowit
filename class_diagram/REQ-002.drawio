        <mxCell id="baseOAuth" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«abstract» «Strategy»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;BaseOAuthClient&lt;/b&gt;&lt;hr/&gt;◇ client_id: str&lt;br/&gt;◇ client_secret: str&lt;br/&gt;◇ redirect_uri: str&lt;hr/&gt;&lt;i&gt;◎ get_consent_url() → str&lt;/i&gt;&lt;br/&gt;&lt;i&gt;◎ exchange_code(code: str) → TokenPair&lt;/i&gt;&lt;br/&gt;&lt;i&gt;◎ refresh(token: str) → str&lt;/i&gt;" vertex="1">
          <mxGeometry height="240" width="280" x="80" y="80" as="geometry" />
        </mxCell>
        <mxCell id="tokenMgr" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«Template Method»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;TokenManager&lt;/b&gt;&lt;hr/&gt;◇ secret_key: str&lt;br/&gt;◇ access_ttl: int = 1800&lt;br/&gt;◇ refresh_ttl: int = 604800&lt;hr/&gt;◎ issue_access_token(payload: dict) → str&lt;br/&gt;◎ issue_refresh_token(user_id: UUID) → str&lt;br/&gt;◎ rotate_refresh_token(old: str) → str&lt;br/&gt;◎ verify(token: str) → dict" vertex="1">
          <mxGeometry height="240" width="280" x="400" y="80" as="geometry" />
        </mxCell>
        <mxCell id="loginRes" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«dataclass»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;LoginResponse&lt;/b&gt;&lt;hr/&gt;◇ access_token: str&lt;br/&gt;◇ token_type: str = &#39;Bearer&#39;&lt;br/&gt;◇ expires_in: int = 1800&lt;br/&gt;◇ user: UserProfile" vertex="1">
          <mxGeometry height="180" width="280" x="720" y="110" as="geometry" />
        </mxCell>
        <mxCell id="userProf" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«dataclass»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;UserProfile&lt;/b&gt;&lt;hr/&gt;◇ user_id: UUID&lt;br/&gt;◇ email: str&lt;br/&gt;◇ name: str&lt;br/&gt;◇ role: Literal[&#39;User&#39;,&#39;Admin&#39;]&lt;br/&gt;◇ department: str&lt;br/&gt;◇ profile_image_url: Optional[str]&lt;br/&gt;◇ created_at: datetime" vertex="1">
          <mxGeometry height="220" width="280" x="1070" y="90" as="geometry" />
        </mxCell>
        <mxCell id="userRepo" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«ABC» «Repository»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;UserRepository&lt;/b&gt;&lt;hr/&gt;&lt;i&gt;◎ get_by_email(email: str) → User&lt;/i&gt;&lt;br/&gt;&lt;i&gt;◎ upsert(user: User) → User&lt;/i&gt;&lt;br/&gt;&lt;i&gt;◎ update_role(user_id, role) → None&lt;/i&gt;" vertex="1">
          <mxGeometry height="180" width="280" x="1410" y="80" as="geometry" />
        </mxCell>
        <mxCell id="sessRepo" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«ABC» «Repository»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;SessionRepository&lt;/b&gt;&lt;hr/&gt;&lt;i&gt;◎ create(user_id, hash) → Session&lt;/i&gt;&lt;br/&gt;&lt;i&gt;◎ find_by_hash(hash: str) → Session&lt;/i&gt;&lt;br/&gt;&lt;i&gt;◎ revoke(session_id) → None&lt;/i&gt;&lt;br/&gt;&lt;i&gt;◎ revoke_all_for_user(user_id) → int&lt;/i&gt;" vertex="1">
