          <mxGeometry height="120" width="240" x="1200" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="memChk" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b style=&#39;font-size:13px&#39;&gt;MemoryScopeChecker&lt;/b&gt;&lt;hr/&gt;◎ check(req) → Response&lt;br/&gt;&lt;br/&gt;agent_memories.scope" vertex="1">
