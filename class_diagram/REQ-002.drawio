        </mxCell>
        <mxCell id="baseCipher" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«abstract» «Strategy»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;BaseCipher&lt;/b&gt;&lt;hr/&gt;&lt;i&gt;◎ encrypt(plaintext: str) → bytes&lt;/i&gt;&lt;br/&gt;&lt;i&gt;◎ decrypt(ciphertext: bytes) → str&lt;/i&gt;" vertex="1">
          <mxGeometry height="140" width="280" x="80" y="1350" as="geometry" />
        </mxCell>
        <mxCell id="keyMgr" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«Singleton»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;KeyManager&lt;/b&gt;&lt;hr/&gt;◇ _instance: KeyManager&lt;br/&gt;◇ secret_client: SecretManagerClient&lt;hr/&gt;◎ get_instance() → KeyManager&lt;br/&gt;◎ get_master_key(name: str) → bytes&lt;br/&gt;◎ rotate_key(name: str) → None" vertex="1">
          <mxGeometry height="200" width="280" x="400" y="1320" as="geometry" />
        </mxCell>
        <mxCell id="credCat" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«Registry»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;CredentialCatalog&lt;/b&gt;&lt;hr/&gt;◇ _registry: dict[str, str]&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;# node_id → service_type&lt;/span&gt;&lt;hr/&gt;◎ get_service_type(node_id) → Literal[&#39;google&#39;,&#39;slack&#39;,&#39;none&#39;]&lt;br/&gt;◎ register(node_id, service_type) → None&lt;br/&gt;◎ list_by_service(svc) → list[str]" vertex="1">
          <mxGeometry height="250" width="320" x="720" y="1280" as="geometry" />
        </mxCell>
        <mxCell id="credInj" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fontStyle=1;" value="&lt;b&gt;«Facade»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:14px&#39;&gt;CredentialInjectionService&lt;/b&gt;&lt;hr/&gt;◇ catalog: CredentialCatalog&lt;br/&gt;◇ cipher: BaseCipher&lt;br/&gt;◇ oauth_repo: OAuthConnectionRepository&lt;br/&gt;◇ node_repo: NodeDefinitionRepository&lt;br/&gt;◇ permission: PermissionMiddleware&lt;br/&gt;◇ sec_log: SecurityLogRepository&lt;hr/&gt;◎ inject(user_id, node_id, session_id) → NodeContext&lt;br/&gt;◎ revoke_after_execution(ctx) → None&lt;br/&gt;◎ refresh_if_expired(conn) → str" vertex="1">
          <mxGeometry height="280" width="380" x="1080" y="1320" as="geometry" />
        </mxCell>
        <mxCell id="nodeCtx" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«dataclass»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;NodeContext&lt;/b&gt;&lt;hr/&gt;◇ user_id: UUID&lt;br/&gt;◇ session_id: UUID&lt;br/&gt;◇ node_id: str&lt;br/&gt;◇ credentials: Optional[InjectedCredential]&lt;br/&gt;◇ metadata: dict" vertex="1">
          <mxGeometry height="180" width="300" x="1500" y="1320" as="geometry" />
        </mxCell>
        <mxCell id="injCred" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«dataclass»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;InjectedCredential&lt;/b&gt;&lt;hr/&gt;◇ service_type: Literal[&#39;google&#39;,&#39;slack&#39;]&lt;br/&gt;◇ credential_id: str&lt;br/&gt;◇ access_token: str&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;# 평문, 메모리 한정&lt;/span&gt;&lt;br/&gt;◇ expires_at: datetime&lt;br/&gt;◇ scope: list[str]" vertex="1">
          <mxGeometry height="200" width="320" x="1840" y="1320" as="geometry" />
        </mxCell>
        <mxCell id="aesCipher" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b style=&#39;font-size:13px&#39;&gt;AESGCMCipher&lt;/b&gt;&lt;hr/&gt;◇ key: bytes (256-bit)&lt;hr/&gt;◎ encrypt(plaintext: str) → bytes&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;# IV(12) + ciphertext + tag(16)&lt;/span&gt;&lt;br/&gt;◎ decrypt(ciphertext: bytes) → str" vertex="1">
          <mxGeometry height="160" width="280" x="80" y="1660" as="geometry" />
        </mxCell>
        <mxCell id="fernCipher" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b style=&#39;font-size:13px&#39;&gt;FernetCipher&lt;/b&gt;&lt;hr/&gt;◇ fernet: Fernet&lt;hr/&gt;◎ encrypt(plaintext: str) → bytes&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;# Refresh Token 해시용&lt;/span&gt;&lt;br/&gt;◎ decrypt(ciphertext: bytes) → str" vertex="1">
          <mxGeometry height="160" width="280" x="400" y="1660" as="geometry" />
        </mxCell>
        <mxCell id="oauthRepo" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«ABC» «Repository»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;OAuthConnectionRepository&lt;/b&gt;&lt;hr/&gt;&lt;i&gt;◎ create(user_id, service, tokens) → Conn&lt;/i&gt;&lt;br/&gt;&lt;i&gt;◎ get_by_credential_id(cid) → Conn&lt;/i&gt;&lt;br/&gt;&lt;i&gt;◎ get_active_for_user(user_id, service) → Conn&lt;/i&gt;&lt;br/&gt;&lt;i&gt;◎ update_tokens(cid, new_tokens) → None&lt;/i&gt;&lt;br/&gt;&lt;i&gt;◎ revoke(cid) → None&lt;/i&gt;" vertex="1">
          <mxGeometry height="200" width="320" x="720" y="1660" as="geometry" />
        </mxCell>
        <mxCell id="nodeDefRepo" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;«ABC» «Repository»&lt;/b&gt;&lt;br/&gt;&lt;b style=&#39;font-size:13px&#39;&gt;NodeDefinitionRepository&lt;/b&gt;&lt;hr/&gt;&lt;i&gt;◎ get_service_type(node_id) → str&lt;/i&gt;&lt;br/&gt;&lt;i&gt;◎ get_required_connections(node_id) → list&lt;/i&gt;&lt;br/&gt;&lt;i&gt;◎ get_risk_level(node_id) → str&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px;color:#666&#39;&gt;# service_type 조회 전용&lt;br/&gt;# CRUD는 REQ-003 영역&lt;/span&gt;" vertex="1">
