<mxfile host="app.diagrams.net" agent="Claude Code" version="26.0.0">
  <diagram id="req007-execution-engine" name="REQ-007 Execution Engine">
    <mxGraphModel dx="2800" dy="3600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="4000" pageHeight="5000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ============================== -->
        <!-- TITLE                          -->
        <!-- ============================== -->
        <mxCell id="title" value="REQ-007 Execution Engine — LangGraph StateGraph + Strategy + State Machine Pattern" style="text;html=1;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="600" y="30" width="2800" height="50" as="geometry" />
        </mxCell>

        <!-- ============================== -->
        <!-- 2-TIER ARCHITECTURE NOTE       -->
        <!-- ============================== -->
        <mxCell id="tier_note" value="&lt;b&gt;2-Tier Execution Architecture&lt;/b&gt;&lt;hr&gt;&lt;b&gt;Tier 1: LangGraph StateGraph (Primary)&lt;/b&gt;&lt;br&gt;- Supports conditional cycles (circular edges)&lt;br&gt;- Self-Refine loop: evaluate → re-work → re-evaluate&lt;br&gt;- PostgresSaver checkpointer for durability&lt;br&gt;&lt;br&gt;&lt;b&gt;Tier 2: Celery + Redis (Secondary)&lt;/b&gt;&lt;br&gt;- Heavy task offload only (NOT primary orchestrator)&lt;br&gt;- Queues: default, llm (Gemma4 Modal, concurrency 5), external_api&lt;br&gt;- Invoked from within LangGraph nodes via CeleryAsyncBridge" style="shape=note;whiteSpace=wrap;html=1;size=18;align=left;spacingLeft=10;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="2980" y="100" width="420" height="220" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- TIER 1 SEPARATOR                                             -->
        <!-- ============================================================ -->
        <mxCell id="tier1_sep" value="TIER 1 — LangGraph StateGraph (Primary Execution Framework)" style="shape=mxgraph.basic.rect;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=16;fontStyle=1;fontColor=#1565C0;align=center;verticalAlign=middle;rounded=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="100" width="2800" height="40" as="geometry" />
        </mxCell>

        <!-- ============================== -->
        <!-- TOP ROW: Facade + Builder + CompiledStateGraph -->
        <!-- ============================== -->

        <!-- 1. StateGraphExecutor — Facade Pattern -->
        <mxCell id="c1" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;&amp;laquo;Facade&amp;raquo;&lt;/b&gt;&lt;br&gt;&lt;b&gt;StateGraphExecutor&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;- graph_builder: StateGraphBuilder&lt;br&gt;- execution_repo: ExecutionRepository&lt;br&gt;- credential_store: CredentialStore&lt;br&gt;- checkpointer: PostgresSaver&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;+ async execute(execution_id: UUID, workflow_id: UUID,&lt;br&gt;&amp;nbsp;&amp;nbsp;execution_mode: str, payload: dict): ExecutionResult&lt;br&gt;+ async cancel(execution_id: UUID): None&lt;br&gt;+ async pause(execution_id: UUID): None&lt;br&gt;+ async resume(execution_id: UUID): None&lt;br&gt;- _resolve_mode(mode: str): ExecutionModeStrategy&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="180" width="500" height="280" as="geometry" />
        </mxCell>

        <!-- 2. StateGraphBuilder — Builder Pattern -->
        <mxCell id="c2" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;&amp;laquo;Builder&amp;raquo;&lt;/b&gt;&lt;br&gt;&lt;b&gt;StateGraphBuilder&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;- graph: StateGraph[ExecutionState]&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;+ build(workflow: WorkflowSchema,&lt;br&gt;&amp;nbsp;&amp;nbsp;tool_registry: ToolRegistry): CompiledStateGraph&lt;br&gt;- _add_workflow_nodes(workflow: WorkflowSchema): None&lt;br&gt;- _add_edges(workflow: WorkflowSchema): None&lt;br&gt;- _add_conditional_edges(node_id: str,&lt;br&gt;&amp;nbsp;&amp;nbsp;evaluator: QAEvaluatorNode): None&lt;br&gt;- _add_self_refine_loop(drafter_node: str,&lt;br&gt;&amp;nbsp;&amp;nbsp;evaluator_node: str, max_retries: int): None&lt;br&gt;- _compile(checkpointer: PostgresSaver): CompiledStateGraph&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="180" width="500" height="290" as="geometry" />
        </mxCell>

        <!-- 3. ExecutionState — TypedDict -->
        <mxCell id="c3" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;&amp;laquo;LangGraph TypedDict&amp;raquo;&lt;/b&gt;&lt;br&gt;&lt;b&gt;ExecutionState&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;- execution_id: UUID&lt;br&gt;- workflow_id: UUID&lt;br&gt;- current_node: str&lt;br&gt;- node_outputs: dict[str, dict]&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;i&gt;# Annotated[dict, operator.ior] (reducer)&lt;/i&gt;&lt;br&gt;- messages: list[BaseMessage]&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;i&gt;# Annotated[list, operator.add] (append reducer)&lt;/i&gt;&lt;br&gt;- eval_score: Optional[float]&lt;br&gt;- refine_count: int&lt;br&gt;- retry_counts: dict[str, int]&lt;br&gt;- credential_ids: list[str]&lt;br&gt;- permission_source: PermissionSource&lt;br&gt;- status: Literal[&amp;quot;running&amp;quot;, &amp;quot;succeeded&amp;quot;,&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;quot;failed&amp;quot;, &amp;quot;cancelled&amp;quot;, &amp;quot;paused&amp;quot;]&lt;br&gt;- error_summary: Optional[str]&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:10px;color:#666;&quot;&gt;&lt;i&gt;(no methods — pure state channel)&lt;/i&gt;&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1300" y="180" width="420" height="340" as="geometry" />
        </mxCell>

        <!-- 4. CompiledStateGraph — External LangGraph -->
        <mxCell id="c4" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;&amp;laquo;LangGraph External&amp;raquo;&lt;/b&gt;&lt;br&gt;&lt;b&gt;CompiledStateGraph&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;- graph: StateGraph&lt;br&gt;- checkpointer: PostgresSaver&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;+ async ainvoke(state: ExecutionState,&lt;br&gt;&amp;nbsp;&amp;nbsp;config: RunnableConfig): ExecutionState&lt;br&gt;+ async astream(state: ExecutionState,&lt;br&gt;&amp;nbsp;&amp;nbsp;config: RunnableConfig): AsyncIterator[ExecutionState]&lt;br&gt;+ get_state(config: RunnableConfig): StateSnapshot&lt;br&gt;+ update_state(config: RunnableConfig, values: dict): None&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1820" y="180" width="470" height="240" as="geometry" />
        </mxCell>

        <!-- ============================== -->
        <!-- UPPER-MIDDLE ROW: Strategy Pattern -->
        <!-- ============================== -->

        <!-- 5. ExecutionModeStrategy — Abstract / Strategy Pattern -->
        <mxCell id="c5" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;&amp;laquo;abstract&amp;raquo;&lt;/b&gt;&lt;br&gt;&lt;b&gt;&amp;laquo;Strategy Pattern&amp;raquo;&lt;/b&gt;&lt;br&gt;&lt;b&gt;&lt;i&gt;ExecutionModeStrategy&lt;/i&gt;&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;&lt;i&gt;(no fields)&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;+ &lt;i&gt;async dispatch(execution_id: UUID,&lt;br&gt;&amp;nbsp;&amp;nbsp;compiled_graph: CompiledStateGraph,&lt;br&gt;&amp;nbsp;&amp;nbsp;initial_state: ExecutionState): ExecutionResult&lt;/i&gt;&lt;br&gt;+ &lt;i&gt;async cancel(execution_id: UUID): None&lt;/i&gt;&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="200" y="560" width="450" height="210" as="geometry" />
        </mxCell>

        <!-- 6. ServerlessExecutor -->
        <mxCell id="c6" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;ServerlessExecutor&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;- compiled_graph: CompiledStateGraph&lt;br&gt;- celery_app: Celery&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;+ async dispatch(execution_id: UUID,&lt;br&gt;&amp;nbsp;&amp;nbsp;compiled_graph: CompiledStateGraph,&lt;br&gt;&amp;nbsp;&amp;nbsp;initial_state: ExecutionState): ExecutionResult&lt;br&gt;+ async cancel(execution_id: UUID): None&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:10px;color:#666;&quot;&gt;&lt;i&gt;Primary: LangGraph graph.ainvoke()&lt;br&gt;Celery for async offload within nodes&lt;/i&gt;&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#d0cee2;strokeColor=#56517e;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="860" width="400" height="260" as="geometry" />
        </mxCell>

        <!-- 7. AgentExecutor -->
        <mxCell id="c7" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;AgentExecutor&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;- ws_pool: dict[UUID, WebSocket]&lt;br&gt;- hybrid_crypto: HybridCryptoHelper&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;+ async dispatch(execution_id: UUID,&lt;br&gt;&amp;nbsp;&amp;nbsp;compiled_graph: CompiledStateGraph,&lt;br&gt;&amp;nbsp;&amp;nbsp;initial_state: ExecutionState): ExecutionResult&lt;br&gt;+ async cancel(execution_id: UUID): None&lt;br&gt;- _encrypt_credentials_for_agent(&lt;br&gt;&amp;nbsp;&amp;nbsp;credentials: list, agent_public_key: str): bytes&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#d0cee2;strokeColor=#56517e;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="560" y="860" width="430" height="240" as="geometry" />
        </mxCell>

        <!-- ============================== -->
        <!-- CENTER ROW: LangGraph Nodes    -->
        <!-- ============================== -->

        <!-- 8. ToolExecutorNode -->
        <mxCell id="c8" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;&amp;laquo;LangGraph Node&amp;raquo;&lt;/b&gt;&lt;br&gt;&lt;b&gt;ToolExecutorNode&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;- tool_registry: ToolRegistry&lt;br&gt;- retry_policy: RetryPolicy&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;+ async __call__(state: ExecutionState): dict&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;i&gt;# returns state update&lt;/i&gt;&lt;br&gt;+ async _execute_tool(node_id: str, tool_name: str,&lt;br&gt;&amp;nbsp;&amp;nbsp;input: dict, state: ExecutionState): dict&lt;br&gt;+ async _handle_error(error: Exception,&lt;br&gt;&amp;nbsp;&amp;nbsp;state: ExecutionState): dict&lt;br&gt;- _should_retry(error: Exception): bool&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1100" y="600" width="420" height="250" as="geometry" />
        </mxCell>

        <!-- 9. QAEvaluatorNode -->
        <mxCell id="c9" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;&amp;laquo;LangGraph Node&amp;raquo;&lt;/b&gt;&lt;br&gt;&lt;b&gt;QAEvaluatorNode&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;- evaluation_threshold: float = 8.0&lt;br&gt;- max_refine_count: int = 3&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;+ async __call__(state: ExecutionState): dict&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;i&gt;# returns {eval_score, refine_count}&lt;/i&gt;&lt;br&gt;+ async _evaluate(node_output: dict): EvaluationResult&lt;br&gt;- _should_refine(score: float, refine_count: int): bool&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1600" y="600" width="430" height="220" as="geometry" />
        </mxCell>

        <!-- 10. ConditionalRouter -->
        <mxCell id="c10" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;&amp;laquo;conditional_edge&amp;raquo;&lt;/b&gt;&lt;br&gt;&lt;b&gt;ConditionalRouter&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;&lt;i&gt;(no fields — stateless routing functions)&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;+ route_by_score(state: ExecutionState): str&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;i&gt;# returns &amp;quot;next_node&amp;quot; | &amp;quot;drafter&amp;quot; | &amp;quot;force_pass&amp;quot;&lt;/i&gt;&lt;br&gt;+ route_by_status(state: ExecutionState): str&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;i&gt;# returns next node or END&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:10px;color:#666;&quot;&gt;&lt;i&gt;Used with graph.add_conditional_edges(&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;quot;qa_evaluator&amp;quot;, route_by_score, {...})&lt;/i&gt;&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="2100" y="600" width="420" height="240" as="geometry" />
        </mxCell>

        <!-- 11. ParallelBranchNode -->
        <mxCell id="c11" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;&amp;laquo;LangGraph Node&amp;raquo;&lt;/b&gt;&lt;br&gt;&lt;b&gt;ParallelBranchNode&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;&lt;i&gt;(no fields — uses LangGraph Send() API)&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;+ async __call__(state: ExecutionState): list[Send]&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;i&gt;# returns Send() for each branch&lt;/i&gt;&lt;br&gt;- _build_branch_states(&lt;br&gt;&amp;nbsp;&amp;nbsp;branches: list[NodeInstance]): list[Send]&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="2600" y="600" width="400" height="190" as="geometry" />
        </mxCell>

        <!-- ============================== -->
        <!-- SELF-REFINE LOOP ANNOTATION    -->
        <!-- ============================== -->
        <mxCell id="self_refine" value="&lt;b&gt;Self-Refine Loop (LangGraph conditional_edge)&lt;/b&gt;&lt;hr&gt;&lt;pre style=&quot;font-size:12px;margin:4px;&quot;&gt;&#10;  drafter (ToolExecutorNode)&#10;     │&#10;     ▼&#10;  qa_evaluator (QAEvaluatorNode)&#10;     │&#10;     ├── [score &amp;gt;= 8.0] ──────→ next_node ✓&#10;     │&#10;     ├── [score &amp;lt; 8.0 &amp;amp;&amp;amp;      ──→ drafter (CYCLE ↺)&#10;     │    refine_count &amp;lt; 3]&#10;     │&#10;     └── [refine_count &amp;gt;= 3] ──→ force_pass → next_node&#10;&#10;  graph.add_conditional_edges(&#10;    &amp;quot;qa_evaluator&amp;quot;,&#10;    route_by_score,&#10;    {&amp;quot;pass&amp;quot;: &amp;quot;next_node&amp;quot;,&#10;     &amp;quot;fail&amp;quot;: &amp;quot;tool_executor&amp;quot;,&#10;     END: END}&#10;  )&#10;&lt;/pre&gt;" style="shape=note;whiteSpace=wrap;html=1;size=20;align=left;spacingLeft=6;fillColor=#FFCCBC;strokeColor=#E64A19;fontSize=11;verticalAlign=top;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1600" y="880" width="440" height="360" as="geometry" />
        </mxCell>

        <!-- ============================== -->
        <!-- LOWER-MIDDLE: State Machine + Data Classes -->
        <!-- ============================== -->

        <!-- 12. NodeRunner — State Machine -->
        <mxCell id="c12" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;&amp;laquo;State Machine&amp;raquo;&lt;/b&gt;&lt;br&gt;&lt;b&gt;NodeRunner&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;- node_instance: NodeInstance&lt;br&gt;- retry_policy: RetryPolicy&lt;br&gt;- current_status: NodeStatus&lt;br&gt;- attempt: int&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;+ async run(input_payload: dict): NodeRunResult&lt;br&gt;+ async transition(new_status: NodeStatus): None&lt;br&gt;+ async retry(): bool&lt;br&gt;- _calculate_backoff(attempt: int): float&lt;br&gt;- async _record_node_log(result: NodeRunResult): None&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1100" y="1300" width="400" height="270" as="geometry" />
        </mxCell>

        <!-- 13. NodeStatus Enum -->
        <mxCell id="c13" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;&amp;laquo;enum&amp;raquo;&lt;/b&gt;&lt;br&gt;&lt;b&gt;NodeStatus&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;PENDING&lt;br&gt;RUNNING&lt;br&gt;SUCCEEDED&lt;br&gt;FAILED&lt;br&gt;RETRYING&lt;br&gt;CANCELLED&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="1300" width="200" height="200" as="geometry" />
        </mxCell>

        <!-- 14. NodeRunResult -->
        <mxCell id="c14" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;&amp;laquo;dataclass&amp;raquo;&lt;/b&gt;&lt;br&gt;&lt;b&gt;NodeRunResult&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:11px;&quot;&gt;- node_id: str&lt;br&gt;- status: NodeStatus&lt;br&gt;- attempt: int&lt;br&gt;- output_payload: dict&lt;br&gt;- error_message: Optional[str]&lt;br&gt;- duration_ms: int&lt;br&gt;- worker_id: str&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;font-size:10px;color:#666;&quot;&gt;&lt;i&gt;(no methods — pure data)&lt;/i&gt;&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1560" y="1300" width="280" height="240" as="geometry" />
        </mxCell>

        <!-- 15. RetryPolicy -->
