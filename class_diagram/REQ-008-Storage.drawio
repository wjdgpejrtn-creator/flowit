        <!-- ==================== 8. SkillStatus (ENUM) ==================== -->
        <mxCell id="SkillStatus" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;i&gt;&amp;lt;&amp;lt;enum&amp;gt;&amp;gt;&lt;/i&gt;&lt;br/&gt;&lt;i&gt;&amp;lt;&amp;lt;State Machine — 5-State Lifecycle&amp;gt;&amp;gt;&lt;/i&gt;&lt;br/&gt;&lt;b&gt;SkillStatus&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;PROPOSED&lt;br/&gt;PENDING_REVIEW&lt;br/&gt;APPROVED&lt;br/&gt;REJECTED&lt;br/&gt;NEEDS_CLARIFICATION&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=12;fontFamily=Helvetica;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="320" y="1020" width="260" height="190" as="geometry" />
        </mxCell>

        <!-- ==================== 9. SkillWithScore (Data class) ==================== -->
        <mxCell id="SkillWithScore" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;i&gt;&amp;lt;&amp;lt;dataclass&amp;gt;&amp;gt;&lt;/i&gt;&lt;br/&gt;&lt;b&gt;SkillWithScore&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;+ skill: SkillModel&lt;br/&gt;+ fts_score: float&lt;br/&gt;+ vector_score: float&lt;br/&gt;+ combined_score: float&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Helvetica;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1420" y="830" width="250" height="150" as="geometry" />
        </mxCell>

        <!-- ==================== 10. SkillDetail (Data class) ==================== -->
        <mxCell id="SkillDetail" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;i&gt;&amp;lt;&amp;lt;dataclass&amp;gt;&amp;gt;&lt;/i&gt;&lt;br/&gt;&lt;b&gt;SkillDetail&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;+ skill: SkillModel&lt;br/&gt;+ stats: SkillStats&lt;br/&gt;+ recent_reviews: list[SkillReview]&lt;br/&gt;+ dependencies: list[SkillDependency]&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Helvetica;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1720" y="830" width="280" height="150" as="geometry" />
        </mxCell>

        <!-- ==================== 11. SkillRecommendation (Data class) ==================== -->
        <mxCell id="SkillRecommendation" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;i&gt;&amp;lt;&amp;lt;dataclass&amp;gt;&amp;gt;&lt;/i&gt;&lt;br/&gt;&lt;b&gt;SkillRecommendation&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;+ skill_id: UUID&lt;br/&gt;+ name: str&lt;br/&gt;+ reason: str&lt;br/&gt;+ relevance_score: float&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Helvetica;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="2050" y="830" width="250" height="150" as="geometry" />
        </mxCell>

        <!-- ==================== 12. SkillStats (Data class) ==================== -->
        <mxCell id="SkillStats" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;i&gt;&amp;lt;&amp;lt;dataclass — aggregate cache&amp;gt;&amp;gt;&lt;/i&gt;&lt;br/&gt;&lt;b&gt;SkillStats&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;+ skill_id: UUID&lt;br/&gt;+ download_count: int&lt;br/&gt;+ apply_count_total: int&lt;br/&gt;+ apply_count_30d: int&lt;br/&gt;+ unique_applier_count: int&lt;br/&gt;+ avg_rating: float&lt;br/&gt;+ review_count: int&lt;br/&gt;+ hotness_score: float&lt;br/&gt;+ last_applied_at: datetime&lt;br/&gt;+ recomputed_at: datetime&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;+ compute_hotness() -&amp;gt; float&lt;br/&gt;&amp;nbsp;&amp;nbsp;&lt;i&gt;# z(apply_count_30d) + 0.5 * z(avg_rating)&lt;/i&gt;&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Helvetica;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1420" y="1040" width="310" height="310" as="geometry" />
        </mxCell>

        <!-- ==================== 13. SkillReview (Data class) ==================== -->
        <mxCell id="SkillReview" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;i&gt;&amp;lt;&amp;lt;dataclass&amp;gt;&amp;gt;&lt;/i&gt;&lt;br/&gt;&lt;b&gt;SkillReview&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;+ review_id: UUID&lt;br/&gt;+ skill_id: UUID&lt;br/&gt;+ reviewer_user_id: UUID&lt;br/&gt;+ rating: int  &lt;i&gt;{1-5}&lt;/i&gt;&lt;br/&gt;+ comment: str&lt;br/&gt;+ created_at: datetime&lt;br/&gt;+ updated_at: datetime&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;font-size:10px;&quot;&gt;&lt;i&gt;UNIQUE(skill_id, reviewer_user_id)&lt;br/&gt;CHECK(reviewer != owner)&lt;/i&gt;&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Helvetica;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1780" y="1040" width="280" height="270" as="geometry" />
        </mxCell>

        <!-- ==================== 14. SkillDependency (Data class) ==================== -->
        <mxCell id="SkillDependency" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;i&gt;&amp;lt;&amp;lt;dataclass&amp;gt;&amp;gt;&lt;/i&gt;&lt;br/&gt;&lt;b&gt;SkillDependency&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;+ skill_id: UUID&lt;br/&gt;+ requires_skill_id: UUID&lt;br/&gt;+ kind: Literal[&amp;quot;hard&amp;quot;, &amp;quot;soft&amp;quot;]&lt;br/&gt;+ reason: str&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Helvetica;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="2110" y="1040" width="260" height="150" as="geometry" />
        </mxCell>

        <!-- ==================== 15. SkillPromotionLog (Data class) ==================== -->
