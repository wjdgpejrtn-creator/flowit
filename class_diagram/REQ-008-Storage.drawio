        <!-- ==================== 2. WorkflowService ==================== -->
        <mxCell id="WorkflowService" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;i&gt;&amp;lt;&amp;lt;Service Layer&amp;gt;&amp;gt;&lt;/i&gt;&lt;br/&gt;&lt;b&gt;WorkflowService&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;- workflow_repo: WorkflowRepository&lt;br/&gt;- version_manager: WorkflowVersionManager&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;+ async create(owner_id: UUID, schema: WorkflowSchema) -&amp;gt; WorkflowModel&lt;br/&gt;+ async get(workflow_id: UUID, user: PermissionSource) -&amp;gt; WorkflowModel&lt;br/&gt;+ async update(workflow_id: UUID, schema: WorkflowSchema) -&amp;gt; WorkflowModel&lt;br/&gt;+ async delete(workflow_id: UUID) -&amp;gt; None  &lt;i&gt;{soft delete}&lt;/i&gt;&lt;br/&gt;+ async autosave_draft(workflow_id: UUID, draft_spec: DraftSpec) -&amp;gt; None&lt;br/&gt;+ async activate(workflow_id: UUID) -&amp;gt; None  &lt;i&gt;{draft→active}&lt;/i&gt;&lt;br/&gt;+ async archive(workflow_id: UUID) -&amp;gt; None  &lt;i&gt;{active→archived}&lt;/i&gt;&lt;br/&gt;+ async list_by_owner(owner_id: UUID, scope_filter: str) -&amp;gt; list[WorkflowModel]&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Helvetica;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="380" width="580" height="310" as="geometry" />
        </mxCell>

        <!-- ==================== 3. SkillService ==================== -->
        <mxCell id="SkillService" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;i&gt;&amp;lt;&amp;lt;Service Layer&amp;gt;&amp;gt;&lt;/i&gt;&lt;br/&gt;&lt;b&gt;SkillService&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;- skill_repo: SkillRepository&lt;br/&gt;- source_repo: SkillSourceRepository&lt;br/&gt;- application_repo: SkillApplicationRepository&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;+ async propose(owner_id: UUID, condition: str, action: str, rationale: str, session_id: UUID) -&amp;gt; SkillModel&lt;br/&gt;+ async accept_proposed(skill_id: UUID) -&amp;gt; SkillModel  &lt;i&gt;{proposed→pending_review}&lt;/i&gt;&lt;br/&gt;+ async approve(skill_id: UUID, approver_id: UUID) -&amp;gt; SkillModel  &lt;i&gt;{pending_review→approved}&lt;/i&gt;&lt;br/&gt;+ async reject(skill_id: UUID, reason: str) -&amp;gt; SkillModel  &lt;i&gt;{pending_review→rejected}&lt;/i&gt;&lt;br/&gt;+ async request_clarification(skill_id: UUID, question: str) -&amp;gt; SkillModel  &lt;i&gt;{pending_review→needs_clarification}&lt;/i&gt;&lt;br/&gt;+ async answer_clarification(skill_id: UUID, answer: str) -&amp;gt; SkillModel  &lt;i&gt;{needs_clarification→pending_review}&lt;/i&gt;&lt;br/&gt;+ async dismiss(skill_id: UUID) -&amp;gt; None  &lt;i&gt;{proposed→hard delete}&lt;/i&gt;&lt;br/&gt;+ async add_source(skill_id: UUID, source_kind: str, source_ref: dict) -&amp;gt; None  &lt;i&gt;{append-only}&lt;/i&gt;&lt;br/&gt;+ async record_application(skill_id: UUID, workflow_id: UUID, user_id: UUID, session_id: UUID) -&amp;gt; None&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Helvetica;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="700" y="380" width="660" height="370" as="geometry" />
        </mxCell>

        <!-- ==================== 4. MarketplaceSkillService ==================== -->
        <mxCell id="MarketplaceSkillService" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;i&gt;&amp;lt;&amp;lt;Service Layer&amp;gt;&amp;gt;&lt;/i&gt;&lt;br/&gt;&lt;b&gt;MarketplaceSkillService&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;- marketplace_repo: MarketplaceSkillRepository&lt;br/&gt;- stats_repo: SkillStatsRepository&lt;br/&gt;- review_repo: SkillReviewRepository&lt;br/&gt;- dep_repo: SkillDependencyRepository&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;+ async search(query: str, scope_filter: str, category: str, tags: list, sort_by: str, top_k: int, user: PermissionSource) -&amp;gt; list[SkillWithScore]&lt;br/&gt;+ async get_detail(skill_id: UUID) -&amp;gt; SkillDetail&lt;br/&gt;+ async submit_review(skill_id: UUID, user_id: UUID, rating: int, comment: str) -&amp;gt; SkillReview&lt;br/&gt;+ async list_recommended(user_id: UUID) -&amp;gt; list[SkillRecommendation]&lt;br/&gt;+ async promote_scope(skill_id: UUID, to_scope: str, approved_by: UUID) -&amp;gt; None&lt;br/&gt;+ async set_curation(skill_id: UUID, is_featured: bool, is_official: bool, pinned_until: datetime) -&amp;gt; None&lt;br/&gt;+ async deprecate(skill_id: UUID, replaced_by: UUID) -&amp;gt; None&lt;br/&gt;+ async recompute_stats() -&amp;gt; None  &lt;i&gt;{hourly cron}&lt;/i&gt;&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Helvetica;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="1420" y="380" width="620" height="360" as="geometry" />
        </mxCell>

        <!-- ==================== 5. PolicyDocumentService ==================== -->
        <mxCell id="PolicyDocumentService" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;i&gt;&amp;lt;&amp;lt;Service Layer&amp;gt;&amp;gt;&lt;/i&gt;&lt;br/&gt;&lt;b&gt;PolicyDocumentService&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;- policy_repo: PolicyDocumentRepository&lt;br/&gt;- extraction_repo: PolicyExtractionRepository&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;+ async ingest_from_parsed_document(parsed_doc_id: UUID, owner_id: UUID) -&amp;gt; PolicyDocumentModel&lt;br/&gt;+ async search_policies(query_embedding: list[float], owner_id: UUID, top_k: int) -&amp;gt; list[PolicyExtraction]&lt;br/&gt;+ async delete_policy(policy_id: UUID) -&amp;gt; None  &lt;i&gt;{CASCADE to extractions}&lt;/i&gt;&lt;br/&gt;+ async reembed(policy_id: UUID) -&amp;gt; None&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Helvetica;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="2100" y="380" width="560" height="250" as="geometry" />
        </mxCell>

        <!-- ==================== 6. WorkflowVersionManager ==================== -->
        <mxCell id="WorkflowVersionManager" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;WorkflowVersionManager&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;- version_repo: WorkflowVersionRepository&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;+ async create_snapshot(workflow_id: UUID, version: int, snapshot: dict) -&amp;gt; None&lt;br/&gt;+ async list_versions(workflow_id: UUID, limit: int = 20) -&amp;gt; list[WorkflowVersion]&lt;br/&gt;+ async restore_version(workflow_id: UUID, version: int) -&amp;gt; WorkflowModel&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Helvetica;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="60" y="770" width="480" height="180" as="geometry" />
        </mxCell>

        <!-- ==================== 7. WorkflowStatus (ENUM) ==================== -->
        <mxCell id="WorkflowStatus" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;i&gt;&amp;lt;&amp;lt;enum&amp;gt;&amp;gt;&lt;/i&gt;&lt;br/&gt;&lt;i&gt;&amp;lt;&amp;lt;State Machine&amp;gt;&amp;gt;&lt;/i&gt;&lt;br/&gt;&lt;b&gt;WorkflowStatus&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:8px;text-align:left;&quot;&gt;DRAFT&lt;br/&gt;ACTIVE&lt;br/&gt;ARCHIVED&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=12;fontFamily=Helvetica;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="60" y="1020" width="220" height="150" as="geometry" />
