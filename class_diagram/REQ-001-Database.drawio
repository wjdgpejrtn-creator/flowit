          <mxGeometry x="1830" y="420" width="420" height="170" as="geometry" />
        </mxCell>

        <!-- 9. AgentRepository -->
        <mxCell id="AgentRepo" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;AgentRepository&lt;/b&gt;&lt;br&gt;&lt;i&gt;extends BaseRepository[AgentModel]&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;&lt;i&gt;(inherited fields)&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;+ register(agent: AgentModel): AgentModel&lt;br&gt;+ heartbeat(agent_id: UUID): None&lt;br&gt;+ get_public_key(agent_id: UUID): str&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Consolas;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="2280" y="420" width="380" height="170" as="geometry" />
        </mxCell>

        <!-- ROW 2 of Repos (y=660) -->

        <!-- 10. SkillRepository -->
        <mxCell id="SkillRepo" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;SkillRepository&lt;/b&gt;&lt;br&gt;&lt;i&gt;extends BaseRepository[SkillModel]&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;&lt;i&gt;(inherited fields)&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;+ create(skill: SkillModel): SkillModel&lt;br&gt;+ approve(skill_id: UUID): None&lt;br&gt;+ search(query: str, top_k: int): list[SkillModel]&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Consolas;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="670" width="380" height="170" as="geometry" />
        </mxCell>

        <!-- 11. MarketplaceSkillRepository -->
        <mxCell id="MarketplaceSkillRepo" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;MarketplaceSkillRepository&lt;/b&gt;&lt;br&gt;&lt;i&gt;extends BaseRepository[SkillModel]&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;&lt;i&gt;(inherited fields)&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;+ search(query: str, scope_filter: str, category: str,&lt;br&gt;         tags: list, sort_by: str, top_k: int): list[SkillWithScore]&lt;br&gt;+ get_with_stats(skill_id: UUID): SkillDetail&lt;br&gt;+ list_recommended_for_user(user_id: UUID): list&lt;br&gt;+ list_dependencies(skill_id: UUID): list&lt;br&gt;+ submit_review(skill_id: UUID, user_id: UUID,&lt;br&gt;         rating: int, comment: str): Review&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Consolas;fontSize=11;" vertex="1" parent="1">
