        <!-- 22. SecureAccessHelper -->
        <mxCell id="SecureAccessHelper" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;SecureAccessHelper&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;- credential_store: CredentialStore&lt;br&gt;- fernet: FernetEncryption&lt;br&gt;- aes_gcm: AesGcmEncryption&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;+ retrieve_for_tool(credential_id: str,&lt;br&gt;         permission_source: PermissionSource):&lt;br&gt;         PlaintextCredential&lt;br&gt;+ retrieve_and_wipe(credential_id: str):&lt;br&gt;         PlaintextCredential&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=Consolas;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="2750" y="680" width="380" height="210" as="geometry" />
