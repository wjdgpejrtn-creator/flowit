          <mxGeometry x="1770" y="670" width="400" height="180" as="geometry" />
        </mxCell>

        <!-- 17. WorkflowFeedbackRepository -->
        <mxCell id="FeedbackRepo" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;WorkflowFeedbackRepository&lt;/b&gt;&lt;br&gt;&lt;i&gt;extends BaseRepository&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;&lt;i&gt;(inherited fields)&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;+ create(feedback: FeedbackModel): FeedbackModel&lt;br&gt;+ list_by_workflow(workflow_id: UUID): list&lt;br&gt;+ aggregate(workflow_id: UUID): dict&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Consolas;fontSize=11;" vertex="1" parent="1">
