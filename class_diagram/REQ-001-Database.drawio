<mxfile host="app.diagrams.net" agent="Claude Code" version="26.0.0">
  <diagram id="req001-db-uml" name="REQ-001 Database UML">
    <mxGraphModel dx="4000" dy="5000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="4000" pageHeight="5000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ========== TITLE ========== -->
        <mxCell id="title" value="REQ-001 Database — Repository Pattern + Strategy Pattern&#xa;PostgreSQL 16 + pgvector + SQLAlchemy 2.0 async" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=20;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1200" y="20" width="700" height="60" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- ABSTRACT CLASSES (TOP ROW) — Green #d5e8d4                       -->
        <!-- ================================================================ -->

        <!-- 1. BaseRepository[T] -->
        <mxCell id="BaseRepository" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;i&gt;&amp;lt;&amp;lt;abstract&amp;gt;&amp;gt;&lt;/i&gt;&lt;br&gt;&lt;i&gt;&amp;lt;&amp;lt;Repository Pattern&amp;gt;&amp;gt;&lt;/i&gt;&lt;br&gt;&lt;b&gt;BaseRepository[T]&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;&lt;i&gt;(no fields — generic abstract)&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;+ async create(entity: T): T&lt;br&gt;+ async get(id: UUID): Optional[T]&lt;br&gt;+ async update(id: UUID, entity: T): T&lt;br&gt;+ async delete(id: UUID): bool&lt;br&gt;+ async list(**filters): list[T]&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Consolas;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1350" y="100" width="340" height="220" as="geometry" />
        </mxCell>

        <!-- 19. EncryptionStrategy (abstract) -->
        <mxCell id="EncryptionStrategy" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;i&gt;&amp;lt;&amp;lt;abstract&amp;gt;&amp;gt;&lt;/i&gt;&lt;br&gt;&lt;i&gt;&amp;lt;&amp;lt;Strategy Pattern&amp;gt;&amp;gt;&lt;/i&gt;&lt;br&gt;&lt;b&gt;EncryptionStrategy&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;&lt;i&gt;(no fields)&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;+ encrypt(plaintext: bytes): bytes&lt;br&gt;+ decrypt(ciphertext: bytes): bytes&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Consolas;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="3200" y="100" width="340" height="170" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- CONCRETE REPOSITORIES (MIDDLE — 3 ROWS) — Blue #dae8fc          -->
        <!-- ================================================================ -->

        <!-- ROW 1 of Repos (y=400) -->

        <!-- 2. WorkflowRepository -->
        <mxCell id="WorkflowRepo" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;WorkflowRepository&lt;/b&gt;&lt;br&gt;&lt;i&gt;extends BaseRepository[WorkflowModel]&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;&lt;i&gt;(inherited fields)&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;+ list_by_owner(owner_id: UUID): list[WorkflowModel]&lt;br&gt;+ list_by_scope(scope: str): list[WorkflowModel]&lt;br&gt;+ get_draft(owner_id: UUID, session_id: UUID): Optional[WorkflowModel]&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Consolas;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="430" height="170" as="geometry" />
        </mxCell>

        <!-- 3. ExecutionRepository -->
        <mxCell id="ExecutionRepo" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;ExecutionRepository&lt;/b&gt;&lt;br&gt;&lt;i&gt;extends BaseRepository[ExecutionModel]&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;&lt;i&gt;(inherited fields)&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;+ update_status(id: UUID, status: str): None&lt;br&gt;+ list_by_workflow(workflow_id: UUID): list[ExecutionModel]&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Consolas;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="500" y="420" width="420" height="160" as="geometry" />
        </mxCell>

        <!-- 4. CredentialStore -->
        <mxCell id="CredentialStore" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;CredentialStore&lt;/b&gt;&lt;br&gt;&lt;i&gt;extends BaseRepository[CredentialModel]&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;&lt;i&gt;(inherited fields)&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;+ store(cred: PlaintextCredential): str&lt;br&gt;+ retrieve(credential_id: str): PlaintextCredential&lt;br&gt;+ delete(credential_id: str): bool&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Consolas;fontSize=11;" vertex="1" parent="1">
