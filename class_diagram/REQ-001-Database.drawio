          <mxGeometry x="3180" y="680" width="380" height="170" as="geometry" />
        </mxCell>

        <!-- 24. SessionManager -->
        <mxCell id="SessionManager" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;SessionManager&lt;/b&gt;&lt;br&gt;&lt;i&gt;Dual Layer (Redis + PostgreSQL)&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;- redis_client: Redis&lt;br&gt;- pg_session: AsyncSession&lt;br&gt;- ttl_idle: int = 1800&lt;br&gt;- ttl_max: int = 86400&lt;br&gt;- max_sessions_per_user: int = 25&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;+ create_session(user_id: UUID, kind: str):&lt;br&gt;         ChatSessionModel&lt;br&gt;+ flush_to_postgres(session_id: UUID): None&lt;br&gt;+ resume_or_create(user_id: UUID,&lt;br&gt;         last_activity_at: datetime): ChatSessionModel&lt;br&gt;+ checkpoint_barrier(session_id: UUID): None&lt;br&gt;+ evict_oldest(user_id: UUID): None&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=Consolas;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="2750" y="930" width="380" height="280" as="geometry" />
