        <!-- ================================================================ -->
        <!-- ENCRYPTION STRATEGY (RIGHT) — Red/Pink #f8cecc                   -->
        <!-- ================================================================ -->

        <!-- 20. FernetEncryption -->
        <mxCell id="FernetEncryption" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;FernetEncryption&lt;/b&gt;&lt;br&gt;&lt;i&gt;implements EncryptionStrategy&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;- master_key: bytes&lt;br&gt;&lt;i&gt;  (from GCP Secret Manager&lt;br&gt;   CREDENTIAL_MASTER_KEY)&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;+ encrypt(plaintext: bytes): bytes&lt;br&gt;+ decrypt(ciphertext: bytes): bytes&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Consolas;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="3080" y="380" width="340" height="190" as="geometry" />
        </mxCell>

        <!-- 21. AesGcmEncryption -->
        <mxCell id="AesGcmEncryption" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;AesGcmEncryption&lt;/b&gt;&lt;br&gt;&lt;i&gt;implements EncryptionStrategy&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;- aes_key: bytes&lt;br&gt;&lt;i&gt;  (from GCP Secret Manager&lt;br&gt;   OAUTH_AES_KEY)&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;text-align:left;&quot;&gt;+ encrypt(plaintext: bytes): tuple[bytes, bytes, bytes]&lt;br&gt;&lt;i&gt;  # ciphertext, iv, tag&lt;/i&gt;&lt;br&gt;+ decrypt(ciphertext: bytes, iv: bytes,&lt;br&gt;         tag: bytes): bytes&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Consolas;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="3450" y="380" width="400" height="210" as="geometry" />
        </mxCell>

