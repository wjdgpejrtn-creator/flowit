FROM python:3.12-slim AS base

# Cloud Run worker: long-running Celery worker + dummy HTTP server (worker_entry).
# Cloud Run serviceлҠ” startup HTTP probeлҘј мҡ”кө¬н•ҳлҜҖлЎң worker_entryк°Җ 8080м—җм„ң
# /healthлҘј serveн•ҳлҠ” лҸҷм•Ҳ background subprocessлЎң celery workerлҘј лқ„мҡҙлӢӨ.
#
# CLAUDE.md (Python 3.12 нҶөмқј) + [[modal_deploy_quirks]] PYTHONPATH нҢЁн„ҙ.

WORKDIR /app

# common_schemas вҖ” м§Ғм ‘ import (editable install)
COPY packages/common_schemas/python /app/packages/common_schemas/python
RUN pip install --no-cache-dir -e /app/packages/common_schemas/python

# nodes_graph вҖ” CatalogNodeExecutorк°Җ get_all_node_classes()лЎң 53мў… л…ёл“ң нҒҙлһҳмҠӨлҘј
# import (ADR-0018). pip install -eлҠ” мқҳмЎҙм„ұ(httpx/fpdf2 вҖ” http_requestВ·pdf_generate
# process кө¬нҳ„л¶„)л§Ң м„Өм№ҳн•ңлӢӨ. nodes_graphлҠ” flat layout(л””л үнҶ лҰ¬ мһҗмІҙк°Җ нҢЁнӮӨм§Җ)мқҙлқј
# setuptools find()к°Җ нҢЁнӮӨм§ҖлҘј л§Өн•‘н•ҳм§Җ лӘ»н•ҳлҜҖлЎң, importлҠ” м•„лһҳ PYTHONPATHмқҳ
# /app/modulesлЎң н•ҙкІ°н•ңлӢӨ (services/execution_engineмқ„ src.*лЎң importн•ҳлҠ” кІғкіј лҸҷмқј л°©мӢқ).
COPY modules/nodes_graph /app/modules/nodes_graph
RUN pip install --no-cache-dir -e /app/modules/nodes_graph

# execution_engine ліё нҢЁнӮӨм§Җ + мқҳмЎҙм„ұ (celery, redis, sqlalchemy, pg8000)
COPY services/execution_engine /app/services/execution_engine
RUN pip install --no-cache-dir -e /app/services/execution_engine[worker]

# мӣҢм»ӨлҠ” services/execution_engineмқ„ CWDлЎң мһЎм•„ `src.*` import мқјкҙҖ.
# /app/modulesлҠ” nodes_graph нҢЁнӮӨм§Җ import кІҪлЎң (flat layout вҖ” мң„ мЈјм„қ м°ёмЎ°).
WORKDIR /app/services/execution_engine
ENV PYTHONPATH=/app/services/execution_engine:/app/modules

EXPOSE 8080

CMD ["python", "-m", "src.worker_entry"]
